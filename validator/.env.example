# --- Platform (required) ---
PLATFORM_BASE_URL=
VALIDATOR_PUBLIC_BASE_URL=

# --- Bittensor (Harnyx Subnet defaults) ---
SUBTENSOR_NETWORK=finney
SUBTENSOR_ENDPOINT=wss://entrypoint-finney.opentensor.ai:443
SUBTENSOR_NETUID=67

# Wallet selection (defaults shown; change if your wallet/hotkey names differ).
SUBTENSOR_WALLET_NAME=harnyx-validator
SUBTENSOR_HOTKEY_NAME=default

# If set, the validator will generate/verify the hotkey file inside the mounted wallet dir.
SUBTENSOR_HOTKEY_MNEMONIC=

# Optional sandbox override. Leave unset to use harnyx/harnyx-subnet-sandbox:finney.
# For staging/testnet, set SANDBOX_IMAGE=harnyx/harnyx-subnet-sandbox:testnet.
# SANDBOX_IMAGE=

# --- Evaluation concurrency ---
# Per-artifact task workers. External validators default to 10.
VALIDATOR_TASK_PARALLELISM=10

# --- Tool LLM (miner tool calls) ---
TOOL_LLM_PROVIDER=chutes
CHUTES_API_KEY=

# --- Search tools ---
SEARCH_PROVIDER=desearch
DESEARCH_API_KEY=

# --- Optional Sentry ---
# Default sends validator failures to the Harnyx-managed Sentry project.
# Clear SENTRY_DSN to disable validator error reporting.
SENTRY_DSN=https://560346a36dba1d43fc0338ba102107d3@o4511036126396416.ingest.us.sentry.io/4511071147720704
SENTRY_ENVIRONMENT=prod
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0.05

# --- Scoring LLM (structured output; chutes uses JSON-only fallback) ---
SCORING_LLM_PROVIDER=chutes
